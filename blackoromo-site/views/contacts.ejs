    <div class="scroll-animate" style="text-align:center;margin-top:2rem;"><p style="background:rgba(212,175,55,0.1);border-radius:40px;padding:12px;display:inline-block;"><i class="fas fa-calendar-check"></i> Бажаєте забронювати столик? Зателефонуйте або напишіть у чат!</p></div>
</div>
`, styles, scripts }) %>