    <div class="contacts-grid scroll-animate">
        <div class="contact-info-card"><i class="fas fa-phone-alt"></i><h3>Телефон</h3><a href="tel:+380683665540">+380 (68) 366 5540</a><p style="margin-top:8px;font-size:0.85rem;">(дзвінки, Viber, WhatsApp)</p></div>
        <div class="contact-info-card"><i class="fab fa-telegram-plane"></i><h3>Telegram</h3><a href="https://t.me/MARINA_85_CH" target="_blank">@MARINA_85_CH</a><p style="margin-top:8px;font-size:0.85rem;">Напишіть нам у Telegram</p></div>
