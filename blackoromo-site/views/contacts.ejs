<%
const styles = `
    .contacts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin: 2rem 0; }
    .contact-info-card { background: rgba(20,18,16,0.7); backdrop-filter: blur(8px); border-radius: 32px; padding: 1.8rem; text-align: center; border: 1px solid rgba(212,175,55,0.2); transition: 0.3s; }
    .contact-info-card:hover { transform: translateY(-5px); border-color: var(--gold); }
    .contact-info-card i { font-size: 2.5rem; color: var(--gold); margin-bottom: 1rem; }
    .schedule-card { background: rgba(20,18,16,0.6); backdrop-filter: blur(8px); border-radius: 32px; padding: 1.5rem; text-align: center; border: 1px solid rgba(212,175,55,0.2); }
    .schedule-item { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px dashed rgba(212,175,55,0.3); }
    .direction-block { background: rgba(20,18,16,0.5); border-radius: 32px; padding: 1.8rem; margin: 2rem 0; border-left: 4px solid var(--gold); }
    .contact-form { background: rgba(20,18,16,0.7); backdrop-filter: blur(8px); border-radius: 32px; padding: 2rem; margin: 2rem 0; border: 1px solid rgba(212,175,55,0.3); }
    .contact-form input, .contact-form textarea { width: 100%; background: #2a241f; border: 1px solid rgba(212,175,55,0.3); border-radius: 60px; padding: 14px 20px; color: white; margin-bottom: 1rem; font-size: 1rem; }
    .contact-form textarea { border-radius: 28px; resize: vertical; }
    .contact-form button { background: linear-gradient(135deg, #d4af37, #b8902a); border: none; padding: 12px 28px; border-radius: 60px; font-weight: 600; cursor: pointer; width: 100%; transition: 0.2s; }
    .map-row { display: flex; gap: 1.5rem; flex-wrap: wrap; margin: 2rem 0; }
    .map-container { flex: 2; min-width: 250px; border-radius: 32px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
    .route-links { flex: 1; background: rgba(20,18,16,0.5); border-radius: 32px; padding: 1.5rem; text-align: center; }
    .route-links a { display: inline-flex; align-items: center; gap: 8px; background: var(--gold); color: #0b0a09; padding: 10px 20px; border-radius: 60px; text-decoration: none; font-weight: 600; margin: 0.5rem; transition: 0.2s; }
    @media (max-width: 768px) { .schedule-item { flex-direction: column; align-items: center; gap: 5px; } .map-row { flex-direction: column; } }
`;
const scripts = `
    const form = document.getElementById('feedbackForm');
    const statusDiv = document.getElementById('formStatus');
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('feedbackName').value.trim();
        const email = document.getElementById('feedbackEmail').value.trim();
        const message = document.getElementById('feedbackMessage').value.trim();
        if (!name || !email || !message) { statusDiv.innerHTML = '<span style="color:#e6a177;">❌ Заповніть всі поля</span>'; return; }
        statusDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Надсилання...';
        try {
            const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, message }) });
            const data = await res.json();
            if (res.ok) { statusDiv.innerHTML = '<span style="color:#2a8f6e;">✅ Дякуємо! Ваше повідомлення надіслано.</span>'; form.reset(); }
            else { statusDiv.innerHTML = '<span style="color:#e6a177;">❌ Помилка: ' + (data.error || 'спробуйте пізніше') + '</span>'; }
        } catch(err) { statusDiv.innerHTML = '<span style="color:#e6a177;">❌ Помилка мережі. Перевірте з\'єднання.</span>'; }
    });
`;
%>

