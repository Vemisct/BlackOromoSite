<%
const styles = `
    .reviews-header { text-align: center; margin-bottom: 2rem; }
    .review-form { max-width: 700px; margin: 0 auto 3rem; background: rgba(20,18,16,0.8); backdrop-filter: blur(12px); border-radius: 48px; padding: 2rem; border: 1px solid rgba(212,175,55,0.3); transition: 0.3s; }
    .review-form:hover { border-color: #d4af37; transform: translateY(-3px); }
    .rating-select { background: #2a241f; color: white; padding: 10px 16px; border-radius: 60px; border: 1px solid rgba(212,175,55,0.3); font-size: 1rem; cursor: pointer; }
    .review-form textarea { background: #2a241f; border: 1px solid rgba(212,175,55,0.2); border-radius: 32px; padding: 16px; color: white; width: 100%; resize: vertical; font-family: inherit; }
    .submit-btn { background: linear-gradient(135deg, #d4af37, #b8902a); border: none; padding: 12px 28px; border-radius: 60px; font-weight: 600; cursor: pointer; width: 100%; }
    .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; margin-top: 2rem; }
    .review-card { background: rgba(20,18,16,0.7); backdrop-filter: blur(8px); border-radius: 32px; padding: 1.8rem; border: 1px solid rgba(212,175,55,0.2); transition: 0.3s; text-align: center; }
    .review-card:hover { transform: translateY(-6px); border-color: #d4af37; }
    .stars { font-size: 1.4rem; letter-spacing: 4px; color: #d4af37; margin-bottom: 1rem; }
    .review-text { font-style: italic; margin: 1rem 0; color: #f0e6d8; }
    .review-author { font-weight: 600; color: #d4af37; margin-top: 0.5rem; }
    @media (max-width: 700px) { .reviews-grid { grid-template-columns: 1fr; } .review-form { padding: 1.5rem; } }
`;
const scripts = `
    async function loadReviews() {
        try {
            const res = await fetch('/api/reviews');
            const reviews = await res.json();
            const container = document.getElementById('reviewsList');
            if (reviews.length === 0) { container.innerHTML = '<div style="text-align:center;">✨ Поки немає відгуків. Будьте першим!</div>'; return; }
            container.innerHTML = '';
            reviews.forEach(rev => {
                const stars = '★'.repeat(rev.rating) + '☆'.repeat(5-rev.rating);
                const div = document.createElement('div');
                div.className = 'review-card';
                div.innerHTML = '<div class="stars">'+stars+'</div><div class="review-text">“'+escapeHtml(rev.text)+'”</div><div class="review-author">— '+escapeHtml(rev.user_name)+'</div><div class="review-date">'+new Date(rev.timestamp).toLocaleDateString('uk-UA')+'</div>';
                container.appendChild(div);
            });
        } catch(e) { document.getElementById('reviewsList').innerHTML = '<div style="text-align:center;">❌ Помилка завантаження відгуків</div>'; }
    }
    document.getElementById('submitReviewBtn').addEventListener('click', async () => {
        const rating = document.getElementById('ratingSelect').value;
        const text = document.getElementById('reviewText').value.trim();
        const statusDiv = document.getElementById('reviewStatus');
        if (!text) { statusDiv.innerHTML = '❌ Напишіть ваш відгук'; return; }
        statusDiv.innerHTML = '⏳ Відправляємо...';
        try {
            const res = await fetch('/api/reviews', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ rating, text }) });
            const data = await res.json();
            if (res.ok) { statusDiv.innerHTML = '✅ Дякуємо! Ваш відгук з’явиться після перевірки.'; document.getElementById('reviewText').value = ''; loadReviews(); }
            else { statusDiv.innerHTML = '❌ ' + (data.error || 'Помилка'); }
        } catch(e) { statusDiv.innerHTML = '❌ Помилка мережі'; }
    });
    function escapeHtml(str) { if (!str) return ''; return str.replace(/[&<>]/g, m => m==='&'?'&amp;':m==='<'?'&lt;':m==='>'?'&gt;':m); }
    loadReviews();
`;
%>

<%- include('layouts/layout', { body: `
<div class="container" style="padding: 40px 0 60px;">
    <div class="reviews-header scroll-animate"><h2 class="section-title">Відгуки наших гостей</h2><p style="max-width:600px;margin:0 auto;opacity:0.8;">Ваша думка – найкраща нагорода для нас. Діліться враженнями!</p></div>
    <div class="review-form scroll-animate">
        <h3 style="margin-bottom:1rem;text-align:center;">Залишити відгук</h3>
        <div style="text-align:center;margin-bottom:1rem;"><label style="margin-right:1rem;">Оцінка:</label><select id="ratingSelect" class="rating-select"><option value="5">★★★★★ (5)</option><option value="4">★★★★☆ (4)</option><option value="3">★★★☆☆ (3)</option><option value="2">★★☆☆☆ (2)</option><option value="1">★☆☆☆☆ (1)</option></select></div>
        <textarea id="reviewText" rows="3" placeholder="Розкажіть про ваш досвід..."></textarea>
        <button id="submitReviewBtn" class="submit-btn" style="margin-top:1.5rem;">📝 Надіслати відгук</button>
        <p id="reviewStatus" style="margin-top:1rem;font-size:0.85rem;text-align:center;"></p>
    </div>
    <div id="reviewsList" class="reviews-grid scroll-animate"><div style="text-align:center;grid-column:1/-1;">Завантаження відгуків...</div></div>
</div>
`, styles, scripts }) %>