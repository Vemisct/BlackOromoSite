<%
const styles = `
    .about-hero { text-align: center; margin-bottom: 2rem; }
    .feature-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; margin: 3rem 0; }
    .feature-item { background: rgba(20,18,16,0.7); backdrop-filter: blur(8px); border-radius: 32px; padding: 1.8rem 1.5rem; text-align: center; transition: all 0.3s ease; border: 1px solid rgba(212, 175, 55, 0.2); }
    .feature-item:hover { transform: translateY(-6px); border-color: var(--gold); background: rgba(30, 26, 22, 0.9); }
    .feature-item i { font-size: 2.5rem; color: var(--gold); margin-bottom: 1rem; }
    .social-links { display: flex; justify-content: center; gap: 1.8rem; margin: 1.5rem 0; }
    .social-links a { color: var(--gold); font-size: 2rem; transition: 0.2s; display: inline-block; }
    .social-links a:hover { transform: translateY(-3px); color: var(--gold-dark); }
    .contact-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem; margin: 2rem 0; }
    .contact-card { background: rgba(20,18,16,0.6); backdrop-filter: blur(8px); border-radius: 28px; padding: 1.2rem 1.8rem; text-align: center; min-width: 210px; border: 1px solid rgba(212, 175, 55, 0.2); transition: 0.2s; }
    .contact-card:hover { border-color: var(--gold); background: rgba(30, 26, 22, 0.8); }
    .contact-card i { font-size: 1.8rem; color: var(--gold); margin-bottom: 10px; display: block; }
    .map-container { border-radius: 32px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3); margin-top: 2rem; }
    .btn-menu-link { background: linear-gradient(135deg, #d4af37, #b8902a); color: #0b0a09; padding: 12px 28px; border-radius: 60px; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 10px; transition: 0.2s; margin-top: 1rem; border: none; }
    .btn-menu-link:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3); }
    .cta-about { background: rgba(212, 175, 55, 0.1); border-radius: 48px; padding: 40px 30px; text-align: center; margin: 50px 0 30px; border: 1px solid rgba(212, 175, 55, 0.3); }
    @media (max-width: 768px) { .feature-list { gap: 1.5rem; } .feature-item { padding: 1.2rem; } .contact-card { min-width: auto; width: 100%; max-width: 280px; } .cta-about { padding: 30px 20px; } }
    @media (max-width: 480px) { .feature-item i { font-size: 2rem; } .social-links a { font-size: 1.6rem; } }
`;
const scripts = `
    document.getElementById('openChatBtnAbout')?.addEventListener('click', () => {
        const chatToggle = document.getElementById('chatToggleBtn');
        if (chatToggle) chatToggle.click();
    });
`;
%>

<%- include('layouts/layout', { body: `
<div class="container" style="padding: 40px 0 60px;">
    <div class="about-hero scroll-animate">
        <h2 class="section-title">Про нас</h2>
        <p style="max-width: 800px; margin: 0 auto; font-size: 1.1rem;">Black Oromo Coffee – це більше, ніж просто кав'ярня. Це місце, де народжується настрій.</p>
    </div>
    <div class="scroll-animate" style="text-align: center; max-width: 800px; margin: 0 auto 3rem;">
        <h3 style="font-size: 1.8rem; margin-bottom: 1rem; font-family: 'Playfair Display', serif;">Наша історія</h3>
        <p>Ми відчинили двері 13 січня 2023 року на вулиці Данила Нечая, 7. За цей час ми стали місцем, де зустрічаються друзі, народжуються ідеї та народжується справжня любов до кави. Кожна чашка готується з душею, кожен десерт – за власними рецептами.</p>
    </div>
    <div class="feature-list scroll-animate">
        <div class="feature-item"><i class="fas fa-tree"></i><h3>Літня тераса</h3><p>Затишний куточок на свіжому повітрі</p></div>
        <div class="feature-item"><i class="fas fa-snowplow"></i><h3>Зимова тераса</h3><p>Тепла і затишна, з видом на вулицю</p></div>
        <div class="feature-item"><i class="fas fa-chair"></i><h3>Барна стійка</h3><p>Спостерігайте за приготуванням кави</p></div>
        <div class="feature-item"><i class="fas fa-music"></i><h3>Завжди музика</h3><p>Приємний фон на телевізорі</p></div>
        <div class="feature-item"><i class="fas fa-hamburger"></i><h3>Фастфуд і не тільки</h3><p>Бургери, снеки, свіжа випічка</p></div>
        <div class="feature-item"><i class="fas fa-seedling"></i><h3>Свіжа кава</h3><p>Тільки зернова, преміальна</p></div>
    </div>
    <div style="text-align: center;">
        <a href="/menu" class="btn-menu-link"><i class="fas fa-utensils"></i> Переглянути повне меню</a>
    </div>
    <div class="scroll-animate" style="margin: 3rem 0;">
        <h2 class="section-title">Контакти та зв'язок</h2>
        <div class="contact-grid">
            <div class="contact-card"><i class="fas fa-phone-alt"></i><strong>Телефон</strong><p><a href="tel:+380683665540" style="color: var(--gold); text-decoration: none;">+380 (68) 366 5540</a></p></div>
            <div class="contact-card"><i class="fas fa-envelope"></i><strong>Email</strong><p><a href="mailto:blackoromo.site.suport@gmail.com" style="color: var(--gold); text-decoration: none;">blackoromo.site.suport@gmail.com</a></p></div>
            <div class="contact-card"><i class="fas fa-map-marker-alt"></i><strong>Адреса</strong><p>вул. Данила Нечая, 7, Крижопіль</p></div>
        </div>
        <div class="social-links">
            <a href="https://www.instagram.com/blackoromocoffee" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram"></i></a>
            <a href="https://www.facebook.com/profile.php?id=61577008466314" target="_blank" rel="noopener noreferrer"><i class="fab fa-facebook"></i></a>
        </div>
        <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2622.3456!2d28.123456!3d48.123456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDjCsDA3JzI0LjQiTiAyOMKwMDcnMzEuMiJF!5e0!3m2!1suk!2sua!4v1234567890123!5m2!1suk!2sua" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" title="Карта розташування"></iframe>
        </div>
    </div>
    <div class="cta-about scroll-animate">
        <i class="fas fa-comment-dots" style="font-size: 2.5rem; color: #d4af37; margin-bottom: 12px; display: inline-block;"></i>
        <h3 style="font-family: 'Playfair Display', serif; margin-bottom: 10px;">Маєте запитання?</h3>
        <p style="margin-bottom: 20px;">Напишіть нам у чат – ми завжди раді допомогти!</p>
        <button id="openChatBtnAbout" class="btn-menu-link" style="background: #d4af37; border: none;"><i class="fas fa-comment"></i> Відкрити чат</button>
    </div>
</div>
`, styles, scripts }) %>