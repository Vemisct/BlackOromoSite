<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> | Black Oromo Coffee</title>
    <meta name="description" content="<%= description || 'Преміальна кава у Крижополі' %>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700&family=Playfair+Display:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
    <!-- Додаткові стилі для конкретної сторінки -->
    <% if (styles) { %><style><%- styles %></style><% } %>
</head>
<body>
    <%- include('../partials/header') %>
    <main>
        <%- body %>
    </main>
    <%- include('../partials/footer') %>
    <%- include('../partials/chat') %>
    <div id="scrollToTopBtn" class="scroll-to-top">
        <i class="fas fa-arrow-up"></i>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/chat-sidebar.js"></script>
    <script>
        // Кнопка "Вгору"
        const scrollBtn = document.getElementById('scrollToTopBtn');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) scrollBtn.classList.add('visible');
            else scrollBtn.classList.remove('visible');
        });
        scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
        
        // Перевірка користувача для userWidget (дублюється в шапці)
        async function checkUser() {
            try {
                const res = await fetch('/api/user');
                if (res.ok) {
                    const user = await res.json();
                    document.getElementById('userWidget').innerHTML = `
                        <div class="user-info">
                            <img src="${user.photo || 'https://ui-avatars.com/api/?background=d4af37&color=0b0a09&name='+encodeURIComponent(user.name)}" class="user-avatar">
                            <span>${user.name}</span>
                            <a href="/logout" class="btn-outline" style="padding:4px 12px;">Вийти</a>
                        </div>
                    `;
                } else {
                    document.getElementById('userWidget').innerHTML = `<a href="/auth/google" class="btn"><i class="fab fa-google"></i> Увійти через Google</a>`;
                }
            } catch(e) { console.log(e); }
        }
        checkUser();
        
        // Анімація скролу
        const animated = document.querySelectorAll('.scroll-animate');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.2 });
        animated.forEach(el => observer.observe(el));
        
        // Специфічний JS для сторінки (якщо є)
        <% if (scripts) { %><%- scripts %><% } %>
    </script>
</body>
</html>